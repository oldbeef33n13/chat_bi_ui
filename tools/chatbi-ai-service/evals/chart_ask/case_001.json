{
  "id": "chart_ask_basic_001",
  "scene": "chart_ask",
  "title": "询问峰值时间",
  "description": "用户询问图表最高点。",
  "tags": ["basic", "peak"],
  "input": {
    "prompt": "最高点在什么时间",
    "nodeId": "chart_alarm_trend",
    "spec": {
      "chartType": "line",
      "bindings": [
        { "role": "x", "field": "stat_date" },
        { "role": "y", "field": "alarm_count", "agg": "sum" }
      ]
    },
    "rows": [
      { "stat_date": "2026-03-01", "alarm_count": 10 },
      { "stat_date": "2026-03-02", "alarm_count": 30 },
      { "stat_date": "2026-03-03", "alarm_count": 18 }
    ]
  },
  "expect": {
    "mustMentionAny": ["2026-03-02", "峰值"],
    "mustHaveSuggestions": true,
    "allowFallback": true
  },
  "score": {
    "weights": {
      "structure": 0.2,
      "semantic": 0.8
    },
    "minimumPassScore": 0.8
  },
  "notes": "标准峰值问答。"
}
