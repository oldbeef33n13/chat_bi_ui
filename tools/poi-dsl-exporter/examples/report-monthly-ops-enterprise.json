    "props": {
      "reportTitle": "网络与经营月度运营报告（2026-02）",
      "tocShow": true,
      "coverEnabled": true,
      "coverTitle": "网络与经营月度运营报告",
      "coverSubtitle": "Monthly Operations & Business Review",
