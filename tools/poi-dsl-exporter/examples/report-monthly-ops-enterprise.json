    "children": [
      {
        "id": "sec_exec",
        "kind": "section",
        "props": { "title": "1. 管理层摘要" },
        "children": [
          {
            "id": "txt_exec_1",
            "kind": "text",
            "props": {
              "text": "经营侧：收入连续四周环比增长，W4 达到 2012 万；毛利率提升至 33.1%。\n运行侧：核心网络可用性维持高位，错误QPS与丢包率持续下降。\n决策建议：把资源向高增长区域倾斜，同时压缩低效告警并强化发布前校验。",
              "format": "plain"
            }
          },
          {
            "id": "chart_exec_combo",
            "kind": "chart",
            "data": { "sourceId": "ds_finance_week", "queryId": "q_finance_week" },
            "props": {
              "chartType": "combo",
              "titleText": "收入与毛利率周趋势",
              "bindings": [
                { "role": "x", "field": "week" },
                { "role": "y", "field": "revenue_m", "agg": "sum" },
                { "role": "y2", "field": "gross_margin_pct", "agg": "avg" }
              ],
              "xAxisTitle": "周",
              "yAxisTitle": "收入(万元)",
              "legendShow": true,
              "optionPatch": {
                "series": [{ "type": "bar" }, { "type": "line" }],
                "yAxis": [{ "name": "Revenue" }, { "name": "Margin%" }]
              }
            }
          },
          {
            "id": "chart_exec_users",
            "kind": "chart",
            "data": { "sourceId": "ds_finance_week", "queryId": "q_finance_week" },
            "props": {
              "chartType": "line",
              "titleText": "活跃用户与续费率",
              "bindings": [
                { "role": "x", "field": "week" },
                { "role": "y", "field": "active_users_k", "agg": "sum" },
                { "role": "y2", "field": "renewal_pct", "agg": "avg" }
              ],
              "legendShow": true,
              "optionPatch": { "series": [{ "type": "line", "smooth": true }] }
            }
          }
        ]
      },
      {
        "id": "sec_sla",
        "kind": "section",
        "props": { "title": "2. 网络质量与SLA" },
        "children": [
          {
            "id": "txt_sla_1",
            "kind": "text",
            "props": {
              "text": "本月核心网络可用性均值 99.96%，SLA 达标率 100%。02-04 出现短时时延波动，主要由跨区流量突增触发，已通过路由调优恢复。",
              "format": "plain"
            }
          },
          {
            "id": "chart_sla_day",
            "kind": "chart",
            "data": { "sourceId": "ds_network_day", "queryId": "q_network_day" },
            "props": {
              "chartType": "line",
              "titleText": "可用性与丢包率（日）",
              "bindings": [
                { "role": "x", "field": "day" },
                { "role": "y", "field": "availability_pct", "agg": "avg" },
                { "role": "y2", "field": "packet_loss_pct", "agg": "avg" }
