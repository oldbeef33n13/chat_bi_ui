            "kind": "text",
            "layout": { "mode": "absolute", "x": 492, "y": 92, "w": 430, "h": 265, "z": 1 },
            "props": {
              "text": "经营洞察：\n1) 直销与线上双轮驱动，线上订单规模增速更快。\n2) 渠道结构优化拉动利润率改善。\n3) 可继续扩大高ROI渠道预算占比。",
              "format": "plain"
            },
            "style": { "bg": "#f8fbff", "pad": 12, "borderW": 1, "borderC": "#dbeafe", "radius": 8 }
          }
