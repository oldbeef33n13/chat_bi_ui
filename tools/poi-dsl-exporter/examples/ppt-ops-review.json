{
  "docId": "ppt_ops_review",
  "docType": "ppt",
  "schemaVersion": "1.0.0",
  "title": "运维复盘汇报",
  "locale": "zh-CN",
  "themeId": "theme.tech.light",
  "dataSources": [
    {
      "id": "ds_ops",
      "type": "static",
      "staticData": [
        { "day": "Mon", "alarm_count": 34, "latency_ms": 22 },
        { "day": "Tue", "alarm_count": 23, "latency_ms": 24 },
        { "day": "Wed", "alarm_count": 27, "latency_ms": 27 },
        { "day": "Thu", "alarm_count": 18, "latency_ms": 23 },
        { "day": "Fri", "alarm_count": 30, "latency_ms": 29 }
      ]
    }
  ],
  "queries": [
    {
      "queryId": "q_ops",
      "sourceId": "ds_ops",
      "kind": "static"
    }
  ],
  "root": {
    "id": "root",
    "kind": "container",
    "props": {
      "size": "16:9",
      "defaultBg": "#ffffff",
      "nativeChartEnabled": true
    },
    "children": [
      {
        "id": "slide_overview",
        "kind": "slide",
        "props": { "title": "运维总览" },
        "layout": { "mode": "absolute", "x": 0, "y": 0, "w": 960, "h": 540 },
        "children": [
          {
            "id": "txt_t1",
            "kind": "text",
            "layout": { "mode": "absolute", "x": 36, "y": 26, "w": 320, "h": 48, "z": 2 },
            "props": { "text": "运维复盘汇报", "format": "plain" },
            "style": { "fontSize": 28, "bold": true }
          },
          {
            "id": "chart_alarm",
            "kind": "chart",
            "layout": { "mode": "absolute", "x": 36, "y": 96, "w": 430, "h": 250, "z": 1 },
            "data": { "sourceId": "ds_ops", "queryId": "q_ops" },
            "props": {
              "chartType": "line",
              "titleText": "告警趋势",
              "bindings": [
                { "role": "x", "field": "day" },
                { "role": "y", "field": "alarm_count", "agg": "sum", "unit": "count" }
              ]
            }
          },
          {
            "id": "chart_latency",
            "kind": "chart",
            "layout": { "mode": "absolute", "x": 492, "y": 96, "w": 430, "h": 250, "z": 1 },
            "data": { "sourceId": "ds_ops", "queryId": "q_ops" },
            "props": {
              "chartType": "bar",
              "titleText": "时延趋势",
              "bindings": [
                { "role": "x", "field": "day" },
                { "role": "y", "field": "latency_ms", "agg": "avg", "unit": "ms" }
              ],
              "optionPatch": {
                "series": [{ "type": "bar" }],
                "xAxis": { "name": "Day" },
                "yAxis": { "name": "Latency(ms)" }
              }
            }
          }
        ]
      },
      {
        "id": "slide_action",
        "kind": "slide",
        "props": { "title": "行动项" },
        "layout": { "mode": "absolute", "x": 0, "y": 0, "w": 960, "h": 540 },
        "children": [
          {
            "id": "txt_action_t",
            "kind": "text",
            "layout": { "mode": "absolute", "x": 40, "y": 26, "w": 320, "h": 48, "z": 2 },
            "props": { "text": "下周行动项", "format": "plain" },
            "style": { "fontSize": 26, "bold": true }
          },
          {
            "id": "txt_action_list",
            "kind": "text",
            "layout": { "mode": "absolute", "x": 40, "y": 100, "w": 880, "h": 260, "z": 1 },
            "props": { "text": "1) 关键链路补容\n2) 统一告警降噪策略\n3) 增加回滚演练", "format": "plain" },
            "style": { "bg": "#f8fbff", "pad": 12, "borderW": 1, "borderC": "#dbeafe", "radius": 8 }
          }
        ]
      }
    ]
  }
}
